[Unit]
Description=Truco Mineiro Online - bridge web (multi-sessão, porta 80)
After=network.target truco-server.service
Wants=truco-server.service

[Service]
Type=simple
User=truco
WorkingDirectory=/opt/truco-mineiro
ExecStart=/usr/bin/python3 /opt/truco-mineiro/client/web_bridge.py 127.0.0.1 5000 80 0.0.0.0
AmbientCapabilities=CAP_NET_BIND_SERVICE
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
